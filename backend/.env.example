# ============================================
# Txilms Backend - Variables de Entorno
# ============================================
# Copia este archivo como .env y completa tus claves.
# En Vercel, estas mismas variables se configuran en:
#   Dashboard > Project > Settings > Environment Variables

# Clave de API de TMDB (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=tu_clave_aqui

# Clave de OMDb (https://www.omdbapi.com/apikey.aspx) - Proporciona IMDb + Rotten Tomatoes
OMDB_API_KEY=tu_clave_aqui

# Supabase (https://supabase.com/dashboard > Project > Settings > API)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu_service_role_key_aqui
